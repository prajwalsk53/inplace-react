generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  TUTOR
  PROVIDER
  ADMIN
  DIRECTOR
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlacementStatus {
  DRAFT
  SUBMITTED
  AWAITING_PROVIDER
  AWAITING_TUTOR
  APPROVED
  ACTIVE
  COMPLETED
  REJECTED
  TERMINATED
}

enum ChangeRequestStatus {
  PENDING_PROVIDER
  PENDING_TUTOR
  APPROVED
  REJECTED
}

model User {
  id               Int            @id @default(autoincrement())
  fullName         String
  email            String         @unique
  password         String
  role             Role
  approvalStatus   ApprovalStatus @default(PENDING)
  rejectionReason  String?
  avatarInitials   String?
  studentId        String?
  academicYear     String?
  programmeType    String?
  isActive         Boolean        @default(true)
  companyId        Int?
  company          Company?       @relation(fields: [companyId], references: [id])
  approvedById     Int?
  approvedBy       User?          @relation("ApprovedUsers", fields: [approvedById], references: [id])
  approvedUsers    User[]         @relation("ApprovedUsers")
  approvedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  placementsAsStudent      Placement[]              @relation("StudentPlacements")
  placementsAsTutor        Placement[]               @relation("TutorPlacements")
  placementsRiskFlagged     Placement[]              @relation("RiskFlaggedBy")
  placementsProviderApproved Placement[]             @relation("ProviderApprovedBy")
  placementNotificationsRaised PlacementNotification[]
  opportunitiesPosted        PlacementOpportunity[]
  visitsConducted          Visit[]                   @relation("TutorVisits")
  reflections               Reflection[]
  documents                 Document[]
  documentsReviewed          Document[]               @relation("DocumentReviewedBy")
  changeRequestsMade         PlacementChangeRequest[] @relation("RequestedBy")
  changeRequestsReviewed     PlacementChangeRequest[] @relation("ReviewedBy")
  sentMessages               Message[]                @relation("SentMessages")
  receivedMessages           Message[]                @relation("ReceivedMessages")
  notifications              Notification[]
  announcementReads          AnnouncementRead[]
  announcementsPosted        Announcement[]           @relation("PostedAnnouncements")
  auditLogs                  AuditLog[]
  otpCodes                   OtpCode[]
  passwordResets             PasswordReset[]
  evaluationsGiven           ProviderEvaluation[]      @relation("EvaluatedBy")
  issuesRaised                ProviderIssue[]          @relation("RaisedBy")
  meetingsRequested           ProviderMeeting[]        @relation("MeetingRequestedBy")

  @@index([role])
  @@index([approvalStatus])
}

model Company {
  id           Int      @id @default(autoincrement())
  name         String
  address      String?
  city         String?
  sector       String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  website      String?
  phone        String?
  description  String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime @default(now())

  users         User[]
  placements    Placement[]
  opportunities PlacementOpportunity[]
  meetings      ProviderMeeting[]
  evaluations   ProviderEvaluation[]
  issues        ProviderIssue[]
  notifications PlacementNotification[]
}

model Placement {
  id              Int             @id @default(autoincrement())
  studentId       Int
  student         User            @relation("StudentPlacements", fields: [studentId], references: [id])
  companyId       Int
  company         Company         @relation(fields: [companyId], references: [id])
  tutorId         Int?
  tutor           User?           @relation("TutorPlacements", fields: [tutorId], references: [id])
  roleTitle       String
  jobDescription  String?
  startDate       DateTime?
  endDate         DateTime?
  salary          String?
  workingPattern  String?
  supervisorName  String?
  supervisorEmail String?
  supervisorPhone String?
  status          PlacementStatus @default(SUBMITTED)
  tutorComments   String?
  riskFlag        Boolean         @default(false)
  riskLevel       String?
  riskNotes       String?
  riskFlaggedAt   DateTime?
  riskFlaggedById Int?
  riskFlaggedBy   User?           @relation("RiskFlaggedBy", fields: [riskFlaggedById], references: [id])
  providerApprovedAt      DateTime?
  providerApprovedById    Int?
  providerApprovedBy      User?     @relation("ProviderApprovedBy", fields: [providerApprovedById], references: [id])
  providerFeedback        String?
  providerFeedbackAt      DateTime?
  providerRejectionReason String?
  providerRejectedAt      DateTime?
  terminatedReason        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  changeRequests PlacementChangeRequest[]
  documents      Document[]
  reflections    Reflection[]
  visits         Visit[]
  providerTokens ProviderToken[]
  evaluations    ProviderEvaluation[]
  issues         ProviderIssue[]
  notifications  PlacementNotification[]

  @@index([status])
}

model PlacementOpportunity {
  id              Int       @id @default(autoincrement())
  companyId       Int
  company         Company   @relation(fields: [companyId], references: [id])
  postedById      Int?
  postedBy        User?     @relation(fields: [postedById], references: [id])
  title           String
  description     String?
  requirements    String?
  salaryRange     String?
  startDateEst    DateTime?
  durationMonths  Int?
  skillsRequired  String?
  deadline        DateTime?
  location        String?
  positions       Int       @default(1)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PlacementChangeRequest {
  id              Int                 @id @default(autoincrement())
  placementId     Int
  placement       Placement           @relation(fields: [placementId], references: [id])
  requestedById   Int
  requestedBy     User                @relation("RequestedBy", fields: [requestedById], references: [id])
  requestType     String
  justification   String
  proposedDetails String?
  status          ChangeRequestStatus @default(PENDING_PROVIDER)
  providerComment String?
  reviewedById    Int?
  reviewedBy      User?               @relation("ReviewedBy", fields: [reviewedById], references: [id])
  tutorComment    String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model Document {
  id               Int        @id @default(autoincrement())
  placementId      Int?
  placement        Placement? @relation(fields: [placementId], references: [id])
  uploadedById     Int
  uploadedBy       User       @relation(fields: [uploadedById], references: [id])
  fileName         String
  filePath         String
  fileType         String?
  fileSize         Int?
  category         String?
  status           String     @default("pending")
  reviewerFeedback String?
  reviewedAt       DateTime?
  reviewedById     Int?
  reviewedBy       User?      @relation("DocumentReviewedBy", fields: [reviewedById], references: [id])
  createdAt        DateTime   @default(now())
}

model Reflection {
  id            Int       @id @default(autoincrement())
  placementId   Int
  placement     Placement @relation(fields: [placementId], references: [id])
  studentId     Int
  student       User      @relation(fields: [studentId], references: [id])
  title         String
  content       String
  weekNumber    Int?
  status        String    @default("draft")
  tutorFeedback String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Visit {
  id            Int       @id @default(autoincrement())
  placementId   Int
  placement     Placement @relation(fields: [placementId], references: [id])
  tutorId       Int
  tutor         User      @relation("TutorVisits", fields: [tutorId], references: [id])
  scheduledAt   DateTime
  durationHours Float     @default(2)
  visitType     String    @default("physical")
  location      String?
  meetingLink   String?
  status        String    @default("scheduled")
  notes         String?
  outcome       String?
  rescheduleProposedAt DateTime?
  rescheduleNotes      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ProviderMeeting {
  id            Int       @id @default(autoincrement())
  companyId     Int
  company       Company   @relation(fields: [companyId], references: [id])
  requestedById Int
  requestedBy   User      @relation("MeetingRequestedBy", fields: [requestedById], references: [id])
  contactName   String?
  contactEmail  String?
  scheduledAt   DateTime?
  durationHours Float     @default(1)
  meetingType   String    @default("physical")
  location      String?
  meetingLink   String?
  agenda        String?
  status        String    @default("scheduled")
  notes         String?
  createdAt     DateTime  @default(now())
}

model ProviderEvaluation {
  id                    Int       @id @default(autoincrement())
  placementId           Int
  placement             Placement @relation(fields: [placementId], references: [id])
  companyId             Int
  company               Company   @relation(fields: [companyId], references: [id])
  evaluatedById         Int
  evaluatedBy           User      @relation("EvaluatedBy", fields: [evaluatedById], references: [id])
  evalPeriod            String    @default("ad_hoc")
  attendance            Int?
  punctuality           Int?
  professionalism       Int?
  technicalSkills       Int?
  communication         Int?
  initiative            Int?
  rating                Int
  strengths             String?
  areasForImprovement   String?
  additionalComments    String?
  recommendFuture       Boolean?
  comments              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([placementId, evalPeriod])
}

model ProviderIssue {
  id              Int       @id @default(autoincrement())
  placementId     Int
  placement       Placement @relation(fields: [placementId], references: [id])
  companyId       Int
  company         Company   @relation(fields: [companyId], references: [id])
  raisedById      Int
  raisedBy        User      @relation("RaisedBy", fields: [raisedById], references: [id])
  title           String
  description     String
  severity        String    @default("medium")
  desiredOutcome  String?
  status          String    @default("open")
  resolutionNotes String?
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PlacementNotification {
  id               Int       @id @default(autoincrement())
  placementId      Int
  placement        Placement @relation(fields: [placementId], references: [id])
  companyId        Int
  company          Company   @relation(fields: [companyId], references: [id])
  raisedById       Int
  raisedBy         User      @relation(fields: [raisedById], references: [id])
  notificationType String
  effectiveDate    DateTime?
  reason           String
  details          String?
  status           String    @default("pending")
  createdAt        DateTime  @default(now())
}

model ProviderToken {
  id          Int       @id @default(autoincrement())
  token       String    @unique
  placementId Int
  placement   Placement @relation(fields: [placementId], references: [id])
  purpose     String    @default("confirm_placement")
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
}

model Announcement {
  id           Int       @id @default(autoincrement())
  title        String
  content      String
  audienceRole Role?
  audienceType String    @default("all")
  targetValue  String?
  isPinned     Boolean   @default(false)
  expiresAt    DateTime?
  postedById   Int
  postedBy     User      @relation("PostedAnnouncements", fields: [postedById], references: [id])
  createdAt    DateTime  @default(now())

  reads AnnouncementRead[]
}

model AnnouncementRead {
  id             Int          @id @default(autoincrement())
  announcementId Int
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  userId         Int
  user           User         @relation(fields: [userId], references: [id])
  readAt         DateTime     @default(now())

  @@unique([announcementId, userId])
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId Int
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  body       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id])
  action        String
  tableAffected String?
  recordId      Int?
  details        String?
  createdAt     DateTime @default(now())
}

model OtpCode {
  id        Int       @id @default(autoincrement())
  userId    Int?
  user      User?     @relation(fields: [userId], references: [id])
  email     String?
  code      String
  purpose   String    @default("email_verification")
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model SystemSetting {
  key   String  @id
  value String?
}


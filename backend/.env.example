# Postgres connection string (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/inplace_db"

# Auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Server
PORT=5002
CLIENT_URL=http://localhost:5175

# SMTP (Nodemailer) - used for OTP, password reset, provider magic-links, notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="InPlace <no-reply@inplace.local>"

# Google reCAPTCHA v2 - leave blank to disable verification in development
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Postgres connection string (Prisma) - use the pooled connection string here (e.g. Neon's "-pooler" host)
DATABASE_URL="postgresql://user:password@localhost:5432/inplace_db"
# Direct (non-pooled) connection string, used only for running migrations. On Neon this is the
# same host without "-pooler" in it. Required because PgBouncer/transaction-mode pooling doesn't
# support the advisory lock Prisma's migrate engine needs - without this, `prisma migrate deploy`
# can hang/timeout with error P1002. Locally this can just be the same value as DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/inplace_db"

# Auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Server
PORT=5002
CLIENT_URL=http://localhost:5175

# SMTP (Nodemailer) - used for OTP, password reset, provider magic-links, notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="InPlace <no-reply@inplace.local>"

# Google reCAPTCHA v2 - leave blank to disable verification in development
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
